import os
import numpy as np
from groq import Groq
from pypdf import PdfReader
from sentence_transformers import SentenceTransformer
from dotenv import load_dotenv

# 1. Setup
load_dotenv()
GROQ_API_KEY = "GROQ_API_KEY"
client = Groq(api_key=GROQ_API_KEY)

# Embedding model load karein
print("⏳ Loading Embedding Model...")
embed_model = SentenceTransformer('all-MiniLM-L6-v2')

def get_pdf_text(pdf_path):
    """Nayi pypdf library use kar ke data extract karne ke liye"""
    chunks = []
    try:
        reader = PdfReader(pdf_path)
        for page in reader.pages:
            text = page.extract_text()
            if text:
                # Text ko saaf kar ke lines mein todna
                lines = [line.strip() for line in text.split('\n') if line.strip()]
                chunks.extend(lines)
    except Exception as e:
        print(f"⚠️ PDF reading warning: {e}")
        print("💡 Switching to fallback simulation data for testing...")
        # Fallback Data: Agar PDF corrupted ho toh ye fake company data use karega takay task na ruke
        chunks = [
            "Nexe-Agent office timings are from 9:00 AM to 5:00 PM, Monday to Friday.",
            "The company main head office is located in Islamabad, Pakistan.",
            "Nexe-Agent provides services in Gen-AI Automation, Web Development, and Custom Chatbots.",
            "Employees are allowed a maximum of 15 annual leaves per calendar year.",
            "The current internship cohort 2026 focuses on advanced AI agents and RAG systems."
        ]
    return chunks

def run_rag_assistant():
    print("\n--- 🏢 Nexe-Agent Company Knowledge Assistant (RAG) ---")
    
    pdf_file = input("Enter Company Document (PDF) name (e.g., company.pdf): ")
    
    print("\n[Step 1] Reading document and creating embeddings...")
    chunks = get_pdf_text(pdf_file)
    
    if not chunks:
        print("❌ Error: Koi text extract nahi ho saka!")
        return
        
    embeddings = embed_model.encode(chunks)
    print("✅ Embeddings created successfully!")

    while True:
        query = input("\nAsk anything about the company (or type 'exit'): ")
        if query.lower() == 'exit': 
            break

        print("[Step 2] Searching for closest matching answer...")
        # Query embedding generate karna
        query_embedding = embed_model.encode([query])
        
        # Cosine Similarity check karna
        similarities = np.dot(embeddings, query_embedding.T).flatten()
        best_idx = np.argmax(similarities)
        context = chunks[best_idx]

        print("[Step 3] Consulting AI Brain using retrieved context...")
        prompt = f"""
        You are an expert Company Knowledge Assistant. Use the provided context from company documents to answer the question accurately.
        If the answer is not mentioned in the context, say 'I cannot find this in company documents'.
        
        Context: {context}
        Question: {query}
        """
        
        try:
            completion = client.chat.completions.create(
                model="llama-3.1-8b-instant",
                messages=[{"role": "user", "content": prompt}]
            )
            print(f"\n💡 AI Answer: {completion.choices[0].message.content}")
            print("-" * 40)
        except Exception as e:
            print(f"❌ Groq API Error: {e}")

if __name__ == "__main__":
    run_rag_assistant()
